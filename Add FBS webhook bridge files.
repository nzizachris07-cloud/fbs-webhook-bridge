# Simple Python Webhook Receiver for FBS (MetaTrader)
# This script receives trade signals from your Android app and prints them.
# You can host this for free on Render, Fly.io, or Railway!

from flask import Flask, request, jsonify
import os

app = Flask(__name__)

# SECURITY TOKEN: Set this to protect your webhook from others.
# If hosting on Render, you can set the environment variable WEBHOOK_TOKEN.
SECURITY_TOKEN = os.environ.get("WEBHOOK_TOKEN", "my_secure_passcode_123")

@app.route('/', methods=['GET'])
def home():
    return "FBS Webhook Bridge is running! Status: Active.", 200

@app.route('/webhook', methods=['POST'])
def webhook_receiver():
    try:
        # 1. Get the JSON data sent from the Android App
        data = request.get_json()
        if not data:
            return jsonify({"status": "error", "message": "No JSON data received"}), 400

        print(f"Received webhook payload: {data}")

        # 2. Check security token
        app_token = data.get("pass_token")
        if app_token != SECURITY_TOKEN:
            print("Unauthorized access attempt: Invalid Token.")
            return jsonify({"status": "error", "message": "Unauthorized: Invalid pass_token"}), 401

        # 3. Extract the Trade Signal Details
        event = data.get("event")            # e.g. "SWEEP_SHORT_ORDER"
        symbol = data.get("symbol")          # e.g. "EURUSD"
        entry_price = data.get("entry_price")
        tp_price = data.get("tp_price")

        print(f"--- NEW SIGNAL DETECTED ---")
        print(f"Action: {event}")
        print(f"Symbol: {symbol}")
        print(f"Entry Price: {entry_price}")
        print(f"Take Profit: {tp_price}")
        print(f"---------------------------")

