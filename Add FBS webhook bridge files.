        return jsonify({"status": "error", "message": str(e)}), 500

if __name__ == '__main__':
    # Get port from environment variable, default to 5000 for local testing
    port = int(os.environ.get("PORT", 5000))
    app.run(host='0.0.0.0', port=port)
